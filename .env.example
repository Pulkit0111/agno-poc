# Bott configuration — copy to .env and fill in. Loaded by the CLI/server entrypoints.
# Every connector/feature is independent: leave a group blank and it simply stays off.

# ── Required to start + chat in Slack ────────────────────────────────────────────
# Slack (HTTP Events API — needs a public URL for the request URLs; see docs):
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# Encryption key for secrets at rest (Codex token, connector tokens). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BOTT_SECRET_KEY=

# Admin emails (comma-separated) — gate the skill curator + model overrides. Include yours.
BOTT_ADMINS=

# ── Model provider ───────────────────────────────────────────────────────────────
# Default is 'codex' (org ChatGPT/Codex subscription — no key). Connect the org token once:
# either have ~/.codex/auth.json on the host, or paste it via Slack App Home → Connect Codex.
MODEL_PROVIDER=codex
# BOTT_CHAT_MODEL=gpt-5.5          # everyday chat model id (optional override)
# BOTT_HEAVY_MODEL=gpt-5.5         # implement/review model id (optional override)
# For other providers instead of codex:
#   MODEL_PROVIDER=openrouter + OPENROUTER_API_KEY=sk-or-...
#   MODEL_PROVIDER=bedrock     + AWS credentials in the environment

# ── Database ─────────────────────────────────────────────────────────────────────
# Unset = local SQLite (agentos.db), fine for testing. Set for Postgres (production):
# DATABASE_URL=postgresql://user:pass@host:5432/bott

# ── GitHub App (Build & Fix / PR review / triage → draft PRs) ────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=            # path to the .pem (or inline GITHUB_APP_PRIVATE_KEY)
GITHUB_WEBHOOK_SECRET=
ALLOWED_POST_REPOS=                     # comma-separated owner/repo the bot may open PRs on
REVIEW_SLACK_CHANNEL=                   # where webhook auto-reviews mirror

# ── Connectors (all optional, read-only) ─────────────────────────────────────────
# Jira + Confluence (Atlassian API token). Confluence falls back to the Jira creds.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
# CONFLUENCE_URL=  CONFLUENCE_USERNAME=  CONFLUENCE_API_KEY=

# Sentry (read + triage):
SENTRY_ORG_SLUG=
SENTRY_API_TOKEN=
# SENTRY_BASE_URL=https://sentry.io     # only if self-hosted

# Google Workspace (Gmail/Drive/Calendar, read-only via domain-wide delegation).
# Admin authorizes the service account for the gmail/drive/calendar .readonly scopes.
GOOGLE_SERVICE_ACCOUNT_PATH=            # path to the service-account JSON key

# Memra (org context layer):
MEMRA_CLIENT_ID=
MEMRA_CLIENT_SECRET=
MEMRA_TOKEN_ENDPOINT=
MEMRA_MCP_ENDPOINT=
MEMRA_SCOPE=

# Spin (publish rendered reports to a hosted URL):
SPIN_API_BASE_URL=
SPIN_API_TOKEN=
SPIN_PUBLIC_ZONE=

# ── Optional (sensible defaults; uncomment to override) ──────────────────────────
# BOTT_HOST=localhost
# BOTT_PORT=7777
# ALLOWED_EMAIL_DOMAIN=axelerant.com
# LOG_LEVEL=INFO
