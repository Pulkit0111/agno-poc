# Bott configuration — copy to .env and fill in. Loaded by the CLI/server entrypoints.

# ── Required ───────────────────────────────────────────────────────────────────
# Slack (the server won't start without these):
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# GitHub App (webhook auto-reviews + posting). PEM via a file path (or inline _KEY):
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# Repos the bot may post reviews to (comma-separated owner/repo) + where to mirror them:
ALLOWED_POST_REPOS=
REVIEW_SLACK_CHANNEL=

# ── Model ───────────────────────────────────────────────────────────────────────
# Easiest: `scripts/run_server.sh --codex` runs both roles on your ChatGPT subscription
# (a local proxy) and needs NO key — nothing to set here.
# Otherwise, use the OpenAI API:
#   OPENAI_API_KEY=sk-...
#   REVIEW_MODEL=gpt-4.1-mini        # strong model for the review
#   MANAGER_MODEL=gpt-4.1-mini       # fast model for chat/routing (defaults to REVIEW_MODEL)
# Any OpenAI-compatible endpoint also works (Azure / OpenRouter / local / a Codex proxy):
#   REVIEW_MODEL_BASE_URL=http://127.0.0.1:10531/v1   (+ MANAGER_MODEL_BASE_URL for the manager)

# ── Optional (sensible defaults; uncomment to override) ──────────────────────────
# WEBHOOK_PORT=8085
# GITHUB_TOKEN=                       # PAT to raise the rate limit for CLI dry-runs
# REVIEW_MAX_TOOL_CALLS=12
# REVIEW_MAX_TOKENS=200000
# REVIEW_MAX_USD=0.50
# REVIEW_DB_PATH=review_poc.db
# LOG_LEVEL=INFO
