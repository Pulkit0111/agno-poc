# pr_reviewer configuration — copy to .env and fill in. Secrets are read from the
# environment at runtime (loaded via python-dotenv by the CLI/server entrypoints).

# --- Model (need EITHER an API key OR a base_url that carries its own auth) ------
OPENAI_API_KEY=sk-...
# Review model id (default: gpt-4.1-mini). gpt-4o-mini / gpt-4o also supported.
REVIEW_MODEL=gpt-4.1-mini

# Point at any OpenAI-compatible endpoint instead of api.openai.com — Azure OpenAI,
# OpenRouter, a self-hosted gateway, a local model (Ollama/LM Studio), or a local proxy
# that uses a ChatGPT/Codex *subscription* token (no API key needed). When BASE_URL is
# set and the endpoint carries its own auth, OPENAI_API_KEY is not required.
# REVIEW_MODEL_BASE_URL=http://127.0.0.1:10531/v1
# REVIEW_MODEL_API_KEY=                      # explicit key override for that endpoint

# --- Per-review budget caps ----------------------------------------------------
REVIEW_MAX_TOOL_CALLS=12
REVIEW_MAX_TOKENS=200000
REVIEW_MAX_USD=0.50

# --- Verdict-gate thresholds (optional; defaults shown) ------------------------
REVIEW_LARGE_DIFF_FILES=5
REVIEW_LARGE_DIFF_LINES=200
REVIEW_MIN_LOOKUPS_FOR_LARGE=3
REVIEW_SUBSTANTIVE_NEW_FILE_LINES=50

# --- GitHub --------------------------------------------------------------------
# Optional PAT to raise the unauthenticated rate limit for CLI dry-runs.
GITHUB_TOKEN=
# GitHub App (webhook auto-reviews). Provide the PEM inline or via a file path.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# --- Slack (required to run the server) ----------------------------------------
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# --- Posting guard & mirroring -------------------------------------------------
# Comma-separated owner/repo allowlist the bot may post reviews to (test repos only).
ALLOWED_POST_REPOS=
# Channel to mirror webhook-triggered reviews into (optional).
REVIEW_SLACK_CHANNEL=

# --- Runtime -------------------------------------------------------------------
LOG_LEVEL=INFO
WEBHOOK_PORT=8085
# SQLite task/trace DB path (default: review_poc.db in the working directory).
REVIEW_DB_PATH=review_poc.db
